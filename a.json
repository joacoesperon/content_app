{
  "name": "Instagram Scheduler A - Receive",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": 3024355,
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": {
          "x": 0,
          "y": 0
        },
        "restore": {
          "parameters": {
            "hook": {
              "data": {
                "editable": "true"
              },
              "label": "My gateway-webhook webhook"
            }
          }
        },
        "parameters": [
          {
            "name": "hook",
            "type": "hook:gateway-webhook",
            "label": "Webhook",
            "required": true
          },
          {
            "name": "maxResults",
            "type": "number",
            "label": "Maximum number of results"
          }
        ]
      }
    },
    {
      "id": 2,
      "module": "datastore:AddRecord",
      "version": 1,
      "parameters": {
        "datastore": 123690
      },
      "mapper": {
        "key": "{{1.post_slug}}",
        "data": {
          "status": "pending",
          "caption": "{{1.caption}}",
          "post_type": "{{1.post_type}}",
          "video_url": "{{1.video_url}}",
          "image_urls": "{{1.image_urls}}",
          "scheduled_at": "{{1.scheduled_at}}"
        },
        "overwrite": true
      },
      "metadata": {
        "designer": {
          "x": 300,
          "y": 0
        },
        "restore": {
          "expect": {
            "overwrite": {
              "mode": "chose"
            }
          },
          "parameters": {
            "datastore": {
              "label": "instagram_scheduled_posts"
            }
          }
        },
        "parameters": [
          {
            "name": "datastore",
            "type": "datastore",
            "label": "Data store",
            "required": true
          }
        ],
        "expect": [
          {
            "name": "key",
            "type": "text",
            "label": "Key"
          },
          {
            "name": "overwrite",
            "type": "boolean",
            "label": "Overwrite an existing record",
            "required": true
          },
          {
            "name": "data",
            "spec": [
              {
                "name": "post_type",
                "type": "text",
                "label": null
              },
              {
                "name": "caption",
                "type": "text",
                "label": null
              },
              {
                "name": "image_urls",
                "type": "text",
                "label": null
              },
              {
                "name": "video_url",
                "type": "text",
                "label": null
              },
              {
                "name": "scheduled_at",
                "type": "text",
                "label": null
              },
              {
                "name": "status",
                "type": "text",
                "label": null
              }
            ],
            "type": "collection",
            "label": "Record"
          }
        ]
      }
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "slots": null,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    },
    "zone": "eu1.make.com",
    "notes": []
  }
}
