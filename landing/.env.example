# ─── Meta Pixel + Conversions API ───────────────────────────────────────────
# Public — used in the browser (Pixel)
NEXT_PUBLIC_META_PIXEL_ID=

# Server-only — used in API routes (CAPI)
META_CAPI_ACCESS_TOKEN=
# Optional: if you want server-side test events while testing CAPI
META_CAPI_TEST_EVENT_CODE=

# ─── Whop webhook ────────────────────────────────────────────────────────────
# Used to verify Whop webhook signature in /api/whop-webhook
WHOP_WEBHOOK_SECRET=

# ─── ConvertKit (Kit) — email capture for lead magnet ────────────────────────
CONVERTKIT_API_KEY=
CONVERTKIT_API_SECRET=
# The form ID where lead magnet emails go
CONVERTKIT_LEADMAGNET_FORM_ID=

# ─── Public site config ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://jesstrading.io
